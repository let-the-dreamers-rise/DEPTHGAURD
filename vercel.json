{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/api" }
  ],
  "functions": {
    "api/health.ts": {
      "maxDuration": 10
    },
    "api/index.ts": {
      "maxDuration": 300,
      "includeFiles": "dist/**"
    },
    "api/[...path].ts": {
      "maxDuration": 300,
      "includeFiles": "dist/**"
    }
  }
}
