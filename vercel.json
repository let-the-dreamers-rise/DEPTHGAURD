{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/[[...path]]" }
  ],
  "functions": {
    "api/[[...path]].ts": {
      "maxDuration": 300,
      "includeFiles": "dist/**"
    }
  }
}
